# LiveKit configuration for ShadowLearn Voice Agent
# Copy this to .env.local and fill in your credentials

# Get these from LiveKit Cloud dashboard: https://cloud.livekit.io/projects/p_/settings/keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# OpenAI API key (provided by user, not stored here)
# This is passed via the session token from frontend