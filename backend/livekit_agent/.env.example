# LiveKit configuration for ShadowLearn Voice Agent
# Copy this to .env and fill in your credentials

# Get these from LiveKit Cloud dashboard: https://cloud.livekit.io/projects/p_/settings/keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# OpenAI API key (for Observer LLM)
# Can also be provided per-session via user metadata
OPENAI_API_KEY=sk-your-openai-key

# Google API key (optional, for main voice agent)
# Can also be provided per-session via user metadata
GOOGLE_API_KEY=your-google-api-key

# Azure Speech (optional, for pronunciation assessment)
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastus
