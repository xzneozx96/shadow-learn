# ShadowLearn Backend Environment Variables
# Copy this file to .env and fill in the values.

# ── TTS Provider ──────────────────────────────────────────────────────────────
# Which TTS provider to use. Default: azure
# Values: azure | minimax
SHADOWLEARN_TTS_PROVIDER=azure

# ── Model / API URLs (optional overrides) ────────────────────────────────────
# Default: https://openrouter.ai/api/v1/chat/completions
# SHADOWLEARN_OPENROUTER_CHAT_URL=

# Default: qwen/qwen3.5-122b-a10b
# SHADOWLEARN_OPENROUTER_MODEL=

# Default: https://api.minimax.io/v1/t2a_v2
# SHADOWLEARN_MINIMAX_TTS_URL=

# ── Limits (optional overrides) ───────────────────────────────────────────────
# Max video duration in seconds. Default: 1200 (20 minutes)
# SHADOWLEARN_MAX_VIDEO_DURATION_SECONDS=

# Max upload size in bytes. Default: 2147483648 (2 GB)
# SHADOWLEARN_MAX_UPLOAD_SIZE_BYTES=

# Allowed video formats. Default: mp4,mkv,webm,mov
# SHADOWLEARN_ALLOWED_VIDEO_FORMATS=

# Translation batch size. Default: 30
# SHADOWLEARN_TRANSLATION_BATCH_SIZE=

# Translation max retries. Default: 2
# SHADOWLEARN_TRANSLATION_MAX_RETRIES=

# ── LiveKit Configuration (for Speak with AI voice agent) ─────────────────────
# Get these from your LiveKit Cloud project dashboard
# SHADOWLEARN_LIVEKIT_URL=wss://your-project.livekit.cloud
# SHADOWLEARN_LIVEKIT_API_KEY=APxxxxxxxx
# SHADOWLEARN_LIVEKIT_API_SECRET=xxxxxxxx

# ── Free Trial — Server Fallback Keys (optional) ─────────────────────────────
# When set, users can try the app without providing their own API keys.
# free_trial_available in /api/config will be true only when all keys required
# for the active providers are set. Leave unset to disable the trial button.
# SHADOWLEARN_OPENROUTER_API_KEY=
# SHADOWLEARN_DEEPGRAM_API_KEY=
# SHADOWLEARN_AZURE_SPEECH_KEY=
# SHADOWLEARN_AZURE_SPEECH_REGION=
# SHADOWLEARN_MINIMAX_API_KEY=

# ── Offshore Gemini Proxy ────────────────────────────────────────────────────
# Backend forwards Gemini-bound traffic (situation generation) to the
# offshore livekit_agent FastAPI so the GFW does not block the call.
# Token is the shared secret with backend/livekit_agent/.env INTERNAL_TOKEN.
# SHADOWLEARN_OFFSHORE_BASE_URL=http://livekit-agent:8082
# SHADOWLEARN_OFFSHORE_INTERNAL_TOKEN=

# ── YouTube Download (optional) ───────────────────────────────────────────────
# Path to Netscape cookies.txt exported from Firefox while signed into a
# throwaway YouTube account. Needed on VPS/datacenter IPs to bypass bot detection.
# Export: yt-dlp --cookies-from-browser firefox --cookies youtube_cookies.txt <url> --skip-download
# SHADOWLEARN_YTDLP_COOKIES_FILE=./youtube_cookies.txt

# ── Collection — YouTube Data API ────────────────────────────────────────────
# Required for the /collection page. Get a key from Google Cloud Console:
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Free quota: 10,000 units/day (8 curated playlists ≈ 32 units/day).
# SHADOWLEARN_YOUTUBE_API_KEY=AIza...

# ── agentic-rag retrieval backend ─────────────────────────────────────────────
# The AI Companion proxies its RAG tools (/api/pageindex/tool) to the agentic-rag
# service. Point this at agentic-rag's OWN URL/port — NOT this backend's port.
# In dev, agentic-rag runs on 8010 (this backend is 8000).
# SHADOWLEARN_AGENTIC_RAG_BASE_URL=http://localhost:8010
# Shared secret to authenticate to agentic-rag as the external full-access
# consumer — must equal agentic-rag's API_SECRET_KEY. Server-side only.
# SHADOWLEARN_AGENTIC_RAG_API_KEY=
