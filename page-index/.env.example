# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Shared secret required on every request (X-API-Key or Authorization: Bearer).
# The app refuses to start if this is empty.
API_SECRET_KEY=
# Comma-separated allowed origins. Use a wildcard ONLY in development.
CORS_ORIGINS=http://localhost:3000

# --- Database ---
# Credentials for the postgres container (docker compose reads these).
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=pageindex
# App connection string — must match the three values above. Host "postgres" under docker compose.
DATABASE_URL=postgresql+asyncpg://user:password@postgres/pageindex

# --- Celery / Redis (use host "redis" under docker compose) ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Storage (mounted as docker volumes) ---
UPLOAD_DIR=./storage/uploads
RESULTS_DIR=./storage/results
MAX_UPLOAD_MB=50

# --- LLM ---
# Default provider is OpenAI. litellm reads these from the environment.
OPENAI_API_KEY=
# Model for the indexing/tree-building pipeline (many calls — use a fast/cheap model).
OPENAI_MODEL=gpt-4o-mini
# Model for retrieval reasoning (single call — use a stronger model). Empty = reuse OPENAI_MODEL.
RETRIEVAL_MODEL=
# Reasoning effort for the retrieval model (OpenRouter): none | low | medium | high
RETRIEVAL_REASONING_EFFORT=none
# Optional: route via OpenRouter by setting this and using an "openrouter/<model>" model name.
OPENROUTER_API_KEY=
# Per-request timeout (seconds) for the retrieval LLM call.
LLM_TIMEOUT_SECONDS=60
