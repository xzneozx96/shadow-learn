{
  "name": "shadowing-companion",
  "private": true,
  "scripts": {
    "dev:fe": "cd frontend && pnpm dev",
    "dev:be": "cd backend && uv run uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx}": [
      "bash -c 'cd frontend && npx eslint \"$@\"' --"
    ],
    "backend/**/*.py": [
      "bash -c 'cd backend && uvx ruff check \"$@\"' --"
    ]
  }
}